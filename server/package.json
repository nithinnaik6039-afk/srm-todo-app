{
  "name": "srm-todo-server",
  "version": "1.0.0",
  "description": "SRM Organization To-Do App — Backend API",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start":    "node server.js",
    "dev":      "nodemon server.js",
    "test":     "node --experimental-vm-modules node_modules/.bin/jest --runInBand --forceExit",
    "test:verbose": "node --experimental-vm-modules node_modules/.bin/jest --runInBand --forceExit --verbose"
  },
  "keywords": [
    "srm",
    "todo",
    "mern"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^6.7.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.0.0",
    "json2csv": "^5.0.7",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^7.3.1",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.2",
    "nodemailer": "^6.9.3",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "jest": "^30.4.2",
    "nodemon": "^3.0.1",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch":       ["**/tests/**/*.test.js"],
    "testTimeout":     30000,
    "verbose":         true,
    "transform":       {}
  }
}
